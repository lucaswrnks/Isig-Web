<%- include('../partials/head') %>
<%- include('../partials/navbar') %>
<%- include('../partials/alerts') %>
<div class="container py-4" style="max-width:600px">
  <div class="card border-0 shadow">
    <div class="card-header text-white" style="background:#16a34a">
      <h5 class="mb-0 fw-bold">
        <i class="bi bi-diagram-3-fill me-2"></i>
        <%= item ? 'Modifier la classe' : 'Nouvelle classe' %>
      </h5>
    </div>
    <div class="card-body p-4">
      <div id="formError" class="alert alert-danger d-none"></div>
      <div class="row g-3">
        <div class="col-12">
          <label class="form-label fw-semibold">Nom de la classe <span class="text-danger">*</span></label>
          <input type="text" id="nom" class="form-control" placeholder="Ex: BTS SIO SLAM 1">
        </div>
        <div class="col-md-6">
          <label class="form-label fw-semibold">Formation <span class="text-danger">*</span></label>
          <select id="id_formation" class="form-select">
            <option value="">Chargement...</option>
          </select>
        </div>
        <div class="col-md-6">
          <label class="form-label fw-semibold">Année <span class="text-danger">*</span></label>
          <select id="annee" class="form-select">
            <option value="1">1ère année</option>
            <option value="2">2ème année</option>
            <option value="3">3ème année</option>
            <option value="4">4ème année</option>
            <option value="5">5ème année</option>
          </select>
        </div>
      </div>
      <div class="d-flex gap-2 mt-4">
        <button id="saveBtn" class="btn text-white" style="background:#16a34a">
          <i class="bi bi-save me-1"></i>Enregistrer
        </button>
        <a href="/classes" class="btn btn-outline-secondary">
          <i class="bi bi-arrow-left me-1"></i>Retour
        </a>
      </div>
    </div>
  </div>
</div>

<script>
const itemId = <%- JSON.stringify(item?.id || null) %>;

async function loadFormations() {
  const res  = await fetch('/api/formations', { credentials: 'include' });
  const data = await res.json();
  const sel  = document.getElementById('id_formation');
  sel.innerHTML = '<option value="">Sélectionner une formation...</option>' +
    data.map(f => `<option value="${f.id}">[${f.type}] ${f.nom}</option>`).join('');
}

async function loadData() {
  if (!itemId) return;
  const res  = await fetch('/api/classes/' + itemId, { credentials: 'include' });
  const data = await res.json();
  document.getElementById('nom').value          = data.nom    || '';
  document.getElementById('annee').value        = data.annee  || 1;
  document.getElementById('id_formation').value = data.id_formation || '';
}

document.getElementById('saveBtn').addEventListener('click', async () => {
  const body = {
    nom:          document.getElementById('nom').value.trim(),
    annee:        parseInt(document.getElementById('annee').value),
    id_formation: parseInt(document.getElementById('id_formation').value),
  };
  const err = document.getElementById('formError');
  err.classList.add('d-none');
  if (!body.nom || !body.id_formation) {
    err.textContent = 'Nom et formation sont obligatoires.';
    err.classList.remove('d-none'); return;
  }
  const url    = itemId ? '/api/classes/' + itemId : '/api/classes';
  const method = itemId ? 'PUT' : 'POST';
  const res    = await fetch(url, {
    method, credentials: 'include',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(body),
  });
  const data = await res.json();
  if (res.ok) window.location.href = '/classes';
  else { err.textContent = data.message; err.classList.remove('d-none'); }
});

loadFormations().then(loadData);
</script>
<%- include('../partials/footer') %>
