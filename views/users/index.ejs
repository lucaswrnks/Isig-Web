<%- include('../partials/head') %>
<%- include('../partials/navbar') %>
<%- include('../partials/alerts') %>
<div class="container-fluid py-4">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="fw-bold mb-0"><i class="bi bi-shield-person-fill text-dark me-2"></i>Utilisateurs</h2>
    <a href="/users/new" class="btn btn-dark"><i class="bi bi-plus-lg me-1"></i>Nouvel utilisateur</a>
  </div>
  <div class="card border-0 shadow-sm mb-3"><div class="card-body py-2"><input type="text" id="searchInput" class="form-control" placeholder="🔍 Rechercher..."></div></div>
  <div class="card border-0 shadow-sm"><div class="card-body p-0"><div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
      <thead class="table-dark"><tr><th>#</th><th>Username</th><th>Email</th><th>Rôle</th><th>Statut</th><th>Dernière connexion</th><th class="text-center">Actions</th></tr></thead>
      <tbody id="tableBody"><tr><td colspan="7" class="text-center py-4"><div class="spinner-border"></div></td></tr></tbody>
    </table>
  </div></div></div>
</div>
<div class="modal fade" id="deleteModal" tabindex="-1"><div class="modal-dialog modal-dialog-centered"><div class="modal-content">
  <div class="modal-header bg-danger text-white"><h5 class="modal-title">Confirmation</h5><button class="btn-close btn-close-white" data-bs-dismiss="modal"></button></div>
  <div class="modal-body">Supprimer cet utilisateur ?</div>
  <div class="modal-footer"><button class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button><button class="btn btn-danger" id="confirmDelete">Supprimer</button></div>
</div></div></div>
<script>
let allData=[]; let deleteId=null;
const modal=new bootstrap.Modal(document.getElementById('deleteModal'));
const roleBadge={admin:'bg-danger',administratif:'bg-secondary',enseignant:'bg-success',etudiant:'bg-thirdery'};
const statusBadge={active:'bg-success',inactive:'bg-warning text-dark',banned:'bg-danger'};
function render(data){
  const tb=document.getElementById('tableBody');
  if(!data.length){tb.innerHTML='<tr><td colspan="7" class="text-center text-muted py-4">Aucun utilisateur</td></tr>';return;}
  tb.innerHTML=data.map(u=>`<tr>
    <td>${u.id}</td>
    <td class="fw-semibold">${u.username}</td>
    <td>${u.email}</td>
    <td><span class="badge ${roleBadge[u.role]||'bg-secondary'}">${u.role}</span></td>
    <td><span class="badge ${statusBadge[u.status]||'bg-secondary'}">${u.status}</span></td>
    <td>${u.lastLogin?new Date(u.lastLogin).toLocaleString('fr-FR'):'–'}</td>
    <td class="text-center">
      <a href="/users/${u.id}/edit" class="btn btn-sm btn-outline-warning me-1"><i class="bi bi-pencil-fill"></i></a>
      <button class="btn btn-sm btn-outline-danger" onclick="askDelete(${u.id})"><i class="bi bi-trash-fill"></i></button>
    </td></tr>`).join('');
}
async function load(){const res=await fetch('/api/users');if(res.status===401){window.location.href='/login';return;}if(res.status===403){document.getElementById('tableBody').innerHTML='<tr><td colspan="7" class="text-center text-danger py-4">Accès réservé aux administrateurs</td></tr>';return;}allData=await res.json();render(allData);}
document.getElementById('searchInput').addEventListener('input',e=>{const q=e.target.value.toLowerCase();render(allData.filter(x=>x.username.toLowerCase().includes(q)||x.email.toLowerCase().includes(q)));});
function askDelete(id){deleteId=id;modal.show();}
document.getElementById('confirmDelete').addEventListener('click',async()=>{const res=await fetch(`/api/users/${deleteId}`,{method:'DELETE'});const d=await res.json();modal.hide();showToast(res.ok?'success':'danger',d.message);if(res.ok)load();});
function showToast(type,msg){const div=document.createElement('div');div.className=`toast align-items-center text-bg-${type} border-0 show mb-2`;div.innerHTML=`<div class="d-flex"><div class="toast-body">${msg}</div><button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button></div>`;document.getElementById('alertContainer').appendChild(div);setTimeout(()=>div.remove(),3000);}
load();
</script>
<%- include('../partials/footer') %>
