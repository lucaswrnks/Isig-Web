<%- include('../partials/head') %>
<%- include('../partials/navbar') %>
<%- include('../partials/alerts') %>
<div class="container py-4" style="max-width:550px">
  <div class="card border-0 shadow">
    <div class="card-header bg-secondary text-white"><h5 class="mb-0 fw-bold"><i class="bi bi-person-lines-fill me-2"></i><%= item?'Modifier':'Nouveau' %> contact</h5></div>
    <div class="card-body p-4">
      <div id="formError" class="alert alert-danger d-none"></div>
      <form id="contactForm" enctype="multipart/form-data">
        <div class="mb-3"><label class="form-label fw-semibold">Nom *</label><input type="text" id="nom" class="form-control"></div>
        <div class="mb-3"><label class="form-label fw-semibold">Email *</label><input type="email" id="email" class="form-control"></div>
        <div class="mb-3"><label class="form-label fw-semibold">Téléphone</label><input type="text" id="telephone" class="form-control"></div>
        <div class="mb-3"><label class="form-label fw-semibold">Photo <small class="text-muted">(jpg, png, gif)</small></label><input type="file" id="photo" class="form-control" accept="image/*"></div>
        <div class="mb-3"><label class="form-label fw-semibold">Fichier joint <small class="text-muted">(pdf, doc...)</small></label><input type="file" id="fichier" class="form-control"></div>
      </form>
      <div class="d-flex gap-2">
        <button id="saveBtn" class="btn btn-secondary text-white"><i class="bi bi-save me-1"></i>Enregistrer</button>
        <a href="/contacts" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Retour</a>
      </div>
    </div>
  </div>
</div>
<script>
const itemId=<%- JSON.stringify(item?.id||null) %>;
async function loadData(){
  if(!itemId)return;
  const d=await(await fetch(`/api/contacts/${itemId}`)).json();
  document.getElementById('nom').value=d.nom||'';
  document.getElementById('email').value=d.email||'';
  document.getElementById('telephone').value=d.telephone||'';
}
document.getElementById('saveBtn').addEventListener('click',async()=>{
  const err=document.getElementById('formError');
  const nom=document.getElementById('nom').value.trim();
  const email=document.getElementById('email').value.trim();
  if(!nom||!email){err.textContent='Nom et email sont obligatoires.';err.classList.remove('d-none');return;}
  const fd=new FormData();
  fd.append('nom',nom); fd.append('email',email); fd.append('telephone',document.getElementById('telephone').value.trim());
  const photo=document.getElementById('photo').files[0];
  const fichier=document.getElementById('fichier').files[0];
  if(photo)fd.append('photo',photo);
  if(fichier)fd.append('fichier',fichier);
  const res=await fetch(itemId?`/api/contacts/${itemId}`:'/api/contacts',{method:itemId?'PUT':'POST',body:fd});
  const data=await res.json();
  if(res.ok)window.location.href='/contacts';
  else{err.textContent=data.message;err.classList.remove('d-none');}
});
loadData();
</script>
<%- include('../partials/footer') %>
