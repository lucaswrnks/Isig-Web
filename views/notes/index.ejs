<%- include('../partials/head') %>
<%- include('../partials/navbar') %>
<%- include('../partials/alerts') %>
<div class="container-fluid py-4">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="fw-bold mb-0"><i class="bi bi-clipboard-data-fill text-info me-2"></i>
      Notes
      <% if (locals.user && locals.user.role === 'etudiant') { %>
      <small class="fs-6 text-muted fw-normal">– Mes notes</small>
      <% } %>
    </h2>
    <% if (locals.user && locals.user.role === 'admin') { %>
    <a href="/notes/new" class="btn btn-info text-white"><i class="bi bi-plus-lg me-1"></i>Ajouter une note</a>
    <% } %>
  </div>
  <div class="card border-0 shadow-sm mb-3"><div class="card-body py-2"><input type="text" id="searchInput" class="form-control" placeholder="🔍 Rechercher par étudiant ou cours..."></div></div>
  <div class="card border-0 shadow-sm"><div class="card-body p-0"><div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
      <thead class="table-info">
        <tr><th>#</th><th>Étudiant</th><th>Cours</th><th>Note</th><th>Appréciation</th> <% if (locals.user && locals.user.role === 'admin') { %><th class="text-center">Actions</th><% } %></tr>
      </thead>
      <tbody id="tableBody"><tr><td colspan="6" class="text-center py-4"><div class="spinner-border text-info"></div></td></tr></tbody>
    </table>
  </div></div></div>
</div>

<div class="modal fade" id="deleteModal" tabindex="-1"><div class="modal-dialog modal-dialog-centered"><div class="modal-content">
  <div class="modal-header bg-danger text-white"><h5 class="modal-title">Confirmation</h5><button class="btn-close btn-close-white" data-bs-dismiss="modal"></button></div>
  <div class="modal-body">Supprimer cette note ?</div>
  <div class="modal-footer"><button class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button><button class="btn btn-danger" id="confirmDelete">Supprimer</button></div>
</div></div></div>

<script>
const isAdmin  = '<%= locals.user?.role %>' === 'admin';
let allData = []; let deleteId = null;
const modal = new bootstrap.Modal(document.getElementById('deleteModal'));

function mention(n) {
  if (n >= 16) return '<span class="badge bg-success">Très bien</span>';
  if (n >= 14) return '<span class="badge bg-primary">Bien</span>';
  if (n >= 12) return '<span class="badge bg-info text-dark">Assez bien</span>';
  if (n >= 10) return '<span class="badge bg-warning text-dark">Passable</span>';
  return '<span class="badge bg-danger">Insuffisant</span>';
}

function render(data) {
  const tb = document.getElementById('tableBody');
  if (!data.length) { 
    // On ajuste le colspan : 6 pour admin, 5 pour les autres
    tb.innerHTML = `<tr><td colspan="${isAdmin ? 6 : 5}" class="text-center text-muted py-4">Aucune note</td></tr>`; 
    return; 
  }
  tb.innerHTML = data.map(n => `<tr>
    <td><span class="badge bg-info text-dark">${n.id}</span></td>
    <td class="fw-semibold">${n.etudiant ? n.etudiant.nom + ' ' + n.etudiant.prenom : '–'}</td>
    <td>${n.cours ? n.cours.nom : '–'}</td>
    <td><strong>${n.note}/20</strong></td>
    <td>${mention(n.note)}</td>
    ${isAdmin ? `
    <td class="text-center">
      <a href="/notes/${n.id}/edit" class="btn btn-sm btn-outline-warning me-1"><i class="bi bi-pencil-fill"></i></a>
      <button class="btn btn-sm btn-outline-danger" onclick="askDelete(${n.id})"><i class="bi bi-trash-fill"></i></button>
    </td>
    ` : ''}
  </tr>`).join('');
}

async function load() {
  const res = await fetch('/api/notes', { credentials: 'include' });
  if (res.status === 401) { window.location.href = '/login'; return; }
  allData = await res.json(); render(allData);
}

document.getElementById('searchInput').addEventListener('input', e => {
  const q = e.target.value.toLowerCase();
  render(allData.filter(x =>
    (x.etudiant?.nom + ' ' + x.etudiant?.prenom).toLowerCase().includes(q) ||
    (x.cours?.nom || '').toLowerCase().includes(q)
  ));
});

function askDelete(id) { deleteId = id; modal.show(); }

document.getElementById('confirmDelete').addEventListener('click', async () => {
  const res = await fetch('/api/notes/' + deleteId, { method: 'DELETE', credentials: 'include' });
  const d   = await res.json();
  modal.hide(); showToast(res.ok ? 'success' : 'danger', d.message);
  if (res.ok) load();
});

function showToast(type, msg) {
  const div = document.createElement('div');
  div.className = 'toast align-items-center text-bg-' + type + ' border-0 show mb-2';
  div.innerHTML = '<div class="d-flex"><div class="toast-body">' + msg + '</div><button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button></div>';
  document.getElementById('alertContainer').appendChild(div);
  setTimeout(() => div.remove(), 3000);
}
load();
</script>
<%- include('../partials/footer') %>
