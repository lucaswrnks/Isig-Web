<%- include('../partials/head') %>
<%- include('../partials/navbar') %>
<%- include('../partials/alerts') %>
<div class="container-fluid py-4">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="fw-bold mb-0"><i class="bi bi-book-fill text-warning me-2"></i>Cours</h2>
    <% if (locals.user && locals.user.role === 'admin') { %>
    <a href="/cours/new" class="btn btn-warning text-dark"><i class="bi bi-plus-lg me-1"></i>Nouveau cours</a>
    <% } %>
  </div>
  <div class="card border-0 shadow-sm mb-3"><div class="card-body py-2"><input type="text" id="searchInput" class="form-control" placeholder="🔍 Rechercher..."></div></div>
  <div class="card border-0 shadow-sm"><div class="card-body p-0"><div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
      <thead class="table-warning"><tr><th>#</th><th>Nom du cours</th><th>Enseignant</th><th class="text-center">Actions</th></tr></thead>
      <tbody id="tableBody"><tr><td colspan="4" class="text-center py-4"><div class="spinner-border text-warning"></div></td></tr></tbody>
    </table>
  </div></div></div>
</div>

<div class="modal fade" id="deleteModal" tabindex="-1"><div class="modal-dialog modal-dialog-centered"><div class="modal-content">
  <div class="modal-header bg-danger text-white"><h5 class="modal-title">Confirmation</h5><button class="btn-close btn-close-white" data-bs-dismiss="modal"></button></div>
  <div class="modal-body">Supprimer ce cours ?</div>
  <div class="modal-footer"><button class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button><button class="btn btn-danger" id="confirmDelete">Supprimer</button></div>
</div></div></div>

<script>
const isAdmin = '<%= locals.user?.role %>' === 'admin';
let allData = []; let deleteId = null;
const modal = new bootstrap.Modal(document.getElementById('deleteModal'));

function render(data) {
  const tb = document.getElementById('tableBody');
  if (!data.length) { tb.innerHTML = '<tr><td colspan="4" class="text-center text-muted py-4">Aucun cours</td></tr>'; return; }
  tb.innerHTML = data.map(c => `<tr>
    <td><span class="badge bg-warning text-dark">${c.id}</span></td>
    <td class="fw-semibold">${c.nom}</td>
    <td>${c.enseignant ? c.enseignant.nom + ' ' + c.enseignant.prenom : '–'}</td>
    <td class="text-center">
      ${isAdmin ? `
      <a href="/cours/${c.id}/edit" class="btn btn-sm btn-outline-warning me-1"><i class="bi bi-pencil-fill"></i></a>
      <button class="btn btn-sm btn-outline-danger" onclick="askDelete(${c.id})"><i class="bi bi-trash-fill"></i></button>
      ` : '<span class="text-muted small">–</span>'}
    </td></tr>`).join('');
}

async function load() {
  const res = await fetch('/api/cours', { credentials: 'include' });
  if (res.status === 401) { window.location.href = '/login'; return; }
  allData = await res.json(); render(allData);
}

document.getElementById('searchInput').addEventListener('input', e => {
  const q = e.target.value.toLowerCase();
  render(allData.filter(x => x.nom.toLowerCase().includes(q)));
});

function askDelete(id) { deleteId = id; modal.show(); }

document.getElementById('confirmDelete').addEventListener('click', async () => {
  const res = await fetch('/api/cours/' + deleteId, { method: 'DELETE', credentials: 'include' });
  const d   = await res.json();
  modal.hide(); showToast(res.ok ? 'success' : 'danger', d.message);
  if (res.ok) load();
});

function showToast(type, msg) {
  const div = document.createElement('div');
  div.className = 'toast align-items-center text-bg-' + type + ' border-0 show mb-2';
  div.innerHTML = '<div class="d-flex"><div class="toast-body">' + msg + '</div><button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button></div>';
  document.getElementById('alertContainer').appendChild(div);
  setTimeout(() => div.remove(), 3000);
}
load();
</script>
<%- include('../partials/footer') %>
