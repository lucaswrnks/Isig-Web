<%- include('../partials/head') %>
<%- include('../partials/navbar') %>
<%- include('../partials/alerts') %>

<div class="container-fluid py-4">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="fw-bold mb-0">
      <i class="bi bi-people-fill me-2" style="color:#16a34a"></i>Étudiants
    </h2>
    <% if (locals.user && locals.user.role === 'admin') { %>
    <a href="/etudiants/new" class="btn btn-primary">
      <i class="bi bi-plus-lg me-1"></i>Nouvel étudiant
    </a>
    <% } %>
  </div>

  <!-- Filtres -->
  <div class="card border-0 shadow-sm mb-3">
    <div class="card-body py-2 d-flex gap-2 flex-wrap align-items-center">
      <input type="text" id="searchInput" class="form-control w-auto flex-grow-1" placeholder="🔍 Rechercher par nom ou prénom...">
      <select id="filterFormation" class="form-select w-auto">
        <option value="">Toutes les formations</option>
      </select>
      <select id="filterClasse" class="form-select w-auto">
        <option value="">Toutes les classes</option>
      </select>
    </div>
  </div>

  <!-- Stats rapides -->
  <div class="row g-2 mb-3" id="statsRow">
    <div class="col-auto">
      <span class="badge" style="background:#16a34a;font-size:.85rem;padding:.5em 1em" id="statTotal">0 étudiant(s)</span>
    </div>
  </div>

  <div class="card border-0 shadow-sm">
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th>#</th>
              <th>Nom</th>
              <th>Prénom</th>
              <th>Classe</th>
              <th>Formation</th>
              <th>Date de naissance</th>
              <th>Téléphone</th>
              <th class="text-center">Actions</th>
            </tr>
          </thead>
          <tbody id="tableBody">
            <tr><td colspan="8" class="text-center py-4">
              <div class="spinner-border" style="color:#16a34a"></div>
            </td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<!-- Modal suppression -->
<div class="modal fade" id="deleteModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header bg-danger text-white">
        <h5 class="modal-title">Confirmation</h5>
        <button class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">Supprimer cet étudiant ? Cette action est irréversible.</div>
      <div class="modal-footer">
        <button class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
        <button class="btn btn-danger" id="confirmDelete">Supprimer</button>
      </div>
    </div>
  </div>
</div>

<!-- Modal contact -->
<div class="modal fade" id="contactModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header text-white" style="background:#16a34a">
        <h5 class="modal-title"><i class="bi bi-envelope-fill me-2"></i>Contacter l'étudiant</h5>
        <button class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <div class="mb-3 text-center">
          <div class="rounded-circle d-inline-flex align-items-center justify-content-center text-white mb-2"
               style="width:56px;height:56px;font-size:1.4rem;background:#16a34a">
            <i class="bi bi-person-fill"></i>
          </div>
          <h5 class="fw-bold mb-1" id="contactNom"></h5>
          <span class="badge" style="background:#16a34a" id="contactClasse"></span>
        </div>
        <hr>
        <div class="d-grid gap-2">
          <a id="contactTel"   href="#" class="btn btn-outline-success d-none"><i class="bi bi-telephone-fill me-2"></i>Appeler : <span id="contactTelNum"></span></a>
          <a id="contactSMS"   href="#" class="btn btn-outline-primary d-none"><i class="bi bi-chat-fill me-2"></i>Envoyer un SMS</a>
          <a id="contactEmail" href="#" class="btn btn-outline-warning d-none"><i class="bi bi-envelope-fill me-2"></i>Envoyer un email</a>
        </div>
        <div id="noContact" class="alert alert-warning d-none mt-3">Aucune information de contact disponible.</div>
      </div>
    </div>
  </div>
</div>

<script>
const isAdmin = '<%= locals.user?.role %>' === 'admin';
let allData      = [];
let allClasses   = [];
let deleteId     = null;
const modal        = new bootstrap.Modal(document.getElementById('deleteModal'));
const contactModal = new bootstrap.Modal(document.getElementById('contactModal'));

function formatDate(d) { return d ? new Date(d).toLocaleDateString('fr-FR') : '–'; }

function render(data) {
  document.getElementById('statTotal').textContent = data.length + ' étudiant(s)';
  const tbody = document.getElementById('tableBody');
  if (!data.length) {
    tbody.innerHTML = '<tr><td colspan="8" class="text-center text-muted py-4">Aucun étudiant trouvé</td></tr>';
    return;
  }
  tbody.innerHTML = data.map(e => {
    const classe   = e.classe  ? e.classe.nom              : '–';
    const formation = e.classe?.formation ? e.classe.formation.nom + ' (' + e.classe.formation.type + ')' : '–';
    return `
    <tr>
      <td><span class="badge" style="background:#16a34a">${e.id}</span></td>
      <td class="fw-semibold">${e.nom}</td>
      <td>${e.prenom}</td>
      <td>${e.classe ? `<span class="badge" style="background:#f0fdf4;color:#15803d;border:1px solid #bbf7d0">${classe}</span>` : '<span class="text-muted small">–</span>'}</td>
      <td class="small text-muted">${formation}</td>
      <td>${formatDate(e.dob)}</td>
      <td>${e.phone ? '<a href="tel:' + e.phone + '" class="text-decoration-none">' + e.phone + '</a>' : '–'}</td>
      <td class="text-center">
        <button class="btn btn-sm btn-outline-info me-1" title="Contacter"
          onclick="contacter('${e.nom} ${e.prenom}', '${e.phone || ''}', '${e.email || ''}', '${classe}')">
          <i class="bi bi-envelope-fill"></i>
        </button>
        ${isAdmin ? `
        <a href="/etudiants/${e.id}/edit" class="btn btn-sm btn-outline-warning me-1" title="Modifier">
          <i class="bi bi-pencil-fill"></i>
        </a>
        <button class="btn btn-sm btn-outline-danger" onclick="askDelete(${e.id})" title="Supprimer">
          <i class="bi bi-trash-fill"></i>
        </button>` : ''}
      </td>
    </tr>`;
  }).join('');
}

async function loadFilters() {
  // Formations
  const fRes = await fetch('/api/formations', { credentials: 'include' });
  const formations = await fRes.json();
  const fSel = document.getElementById('filterFormation');
  formations.forEach(f => {
    const opt = document.createElement('option');
    opt.value = f.id; opt.textContent = '[' + f.type + '] ' + f.nom;
    fSel.appendChild(opt);
  });
  // Classes
  const cRes = await fetch('/api/classes', { credentials: 'include' });
  allClasses = await cRes.json();
  updateClasseSelect();
}

function updateClasseSelect(idFormation = '') {
  const sel = document.getElementById('filterClasse');
  const current = sel.value;
  sel.innerHTML = '<option value="">Toutes les classes</option>';
  const filtered = idFormation ? allClasses.filter(c => String(c.id_formation) === String(idFormation)) : allClasses;
  filtered.forEach(c => {
    const opt = document.createElement('option');
    opt.value = c.id; opt.textContent = c.nom + ' (' + (c.formation?.type || '') + ')';
    sel.appendChild(opt);
  });
  if (current) sel.value = current;
}

async function load() {
  const params = new URLSearchParams(window.location.search);
  let url = '/api/etudiants';
  const qClasse = params.get('id_classe');
  const qFormation = params.get('id_formation');
  if (qClasse) { url += '?id_classe=' + qClasse; document.getElementById('filterClasse').value = qClasse; }
  else if (qFormation) { url += '?id_formation=' + qFormation; document.getElementById('filterFormation').value = qFormation; updateClasseSelect(qFormation); }
  const res = await fetch(url, { credentials: 'include' });
  if (res.status === 401) { window.location.href = '/login'; return; }
  allData = await res.json();
  render(allData);
}

function applyFilters() {
  const q     = document.getElementById('searchInput').value.toLowerCase();
  const fId   = document.getElementById('filterFormation').value;
  const cId   = document.getElementById('filterClasse').value;
  let data = allData;
  if (q)   data = data.filter(e => e.nom.toLowerCase().includes(q) || e.prenom.toLowerCase().includes(q));
  if (cId) data = data.filter(e => String(e.id_classe) === cId);
  else if (fId) data = data.filter(e => e.classe && String(e.classe.id_formation) === fId);
  render(data);
}

document.getElementById('searchInput').addEventListener('input', applyFilters);
document.getElementById('filterFormation').addEventListener('change', function() {
  updateClasseSelect(this.value);
  applyFilters();
});
document.getElementById('filterClasse').addEventListener('change', applyFilters);

function askDelete(id) { deleteId = id; modal.show(); }

document.getElementById('confirmDelete').addEventListener('click', async () => {
  const res  = await fetch('/api/etudiants/' + deleteId, { method: 'DELETE', credentials: 'include' });
  const data = await res.json();
  showToast(res.ok ? 'success' : 'danger', data.message);
  modal.hide();
  if (res.ok) load();
});

function contacter(nom, phone, email, classe) {
  document.getElementById('contactNom').textContent    = nom;
  document.getElementById('contactClasse').textContent = classe;
  const telBtn    = document.getElementById('contactTel');
  const smsBtn    = document.getElementById('contactSMS');
  const emailBtn  = document.getElementById('contactEmail');
  const noContact = document.getElementById('noContact');
  [telBtn, smsBtn, emailBtn, noContact].forEach(el => el.classList.add('d-none'));
  if (phone) {
    document.getElementById('contactTelNum').textContent = phone;
    telBtn.href = 'tel:' + phone; smsBtn.href = 'sms:' + phone;
    telBtn.classList.remove('d-none'); smsBtn.classList.remove('d-none');
  }
  if (email) {
    emailBtn.href = 'mailto:' + email + '?subject=Message ISIG Paris&body=Bonjour ' + nom + ',';
    emailBtn.classList.remove('d-none');
  }
  if (!phone && !email) noContact.classList.remove('d-none');
  contactModal.show();
}

function showToast(type, msg) {
  const div = document.createElement('div');
  div.className = 'toast align-items-center text-bg-' + type + ' border-0 show mb-2';
  div.innerHTML = '<div class="d-flex"><div class="toast-body">' + msg + '</div><button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button></div>';
  document.getElementById('alertContainer').appendChild(div);
  setTimeout(() => div.remove(), 3000);
}

loadFilters().then(load);
</script>
<%- include('../partials/footer') %>
